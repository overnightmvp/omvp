# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# YouTube OAuth
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Email Service
RESEND_API_KEY=

# Anthropic Claude API (SEO content generation)
# Get your API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxx

# Apify API (YouTube video scraping)
# Get your API key from: https://console.apify.com/account/integrations
# Free tier includes $5 credit (~25-100 videos depending on length)
APIFY_API_TOKEN=apify_api_xxx

# Cron Job Security
CRON_SECRET=
